load File.join(File.dirname(File.realpath(__FILE__)), '.symlinks', 'plugins', 'flutter_secure_storage_macos', 'macos', 'Classes', 'flutter_secure_storage_macos.podspec') rescue nil # Dummy load to ensure path exists if needed

# This is the standard Flutter helper loader
load File.expand_path(File.join('..', '..', 'packages', 'flutter_tools', 'bin', 'xcode_backend.sh'), ENV['FLUTTER_ROOT']) rescue nil 
# Wait, the correct way is:
flutter_macos_podfile_setup_path = File.expand_path(File.join('..', '..', 'packages', 'flutter_tools', 'bin', 'podhelper.rb'), ENV['FLUTTER_ROOT'])
load flutter_macos_podfile_setup_path

platform :osx, '11.0'

# CocoaPods analytics sends network stats synchronously affecting your build performance.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner.xcodeproj'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '11.0'
    end
  end
end
