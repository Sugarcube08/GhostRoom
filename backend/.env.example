REDIS_URL=redis://localhost:6379
PORT=4000

# PostgreSQL Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ghostroom
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ghostroom
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Cloudflare R2 / MinIO Configuration
# For local testing with MinIO:
# R2_ACCOUNT_ID=minioadmin
# R2_ACCESS_KEY_ID=minioadmin
# R2_SECRET_ACCESS_KEY=minioadmin
# R2_ENDPOINT=http://localhost:9000
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ghostroom-media
R2_ENDPOINT=

# Media Quotas
MEDIA_DAILY_BYTES_LIMIT=104857600
MEDIA_DAILY_COUNT_LIMIT=50

# Inbox & Rate Limits
INBOX_MAX_MESSAGES=5000
PAIR_PENDING_MAX=50
RATE_LIMIT_HOUR=50
RATE_LIMIT_DAY=500
